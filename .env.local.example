# ============================================
# TeamScope 로컬 개발 환경변수 설정
# ============================================
# 이 파일을 .env.local 로 복사한 뒤 값을 채워주세요.
# cp .env.local.example .env.local

# --- Jira 설정 ---
# 예제 값은 첫 실행 가이드용이며, 시드/자동 동기화에서는 무시됩니다.
JIRA_BASE_URL=https://your-jira-instance.com
JIRA_PAT=your_jira_personal_access_token
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY

# --- GitLab 설정 ---
# 예제 값은 첫 실행 가이드용이며, 시드/자동 동기화에서는 무시됩니다.
GITLAB_BASE_URL=https://your-gitlab-instance.com
GITLAB_PAT=your_gitlab_personal_access_token
GITLAB_PROJECT_ID=123

# --- PostgreSQL 설정 ---
# 로컬 Docker/Colima 기준 기본 포트: 54329
DATABASE_URL=postgresql://teamscope:teamscope@127.0.0.1:54329/teamscope?schema=public

# --- 앱 설정 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
SYNC_CRON_SCHEDULE=0 */6 * * *
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret
# AI 관리 탭에서 저장하는 ChatGPT/Gemini API 키 암호화에 사용합니다.
# 비워두면 BETTER_AUTH_SECRET을 사용합니다.
AI_SETTINGS_ENCRYPTION_KEY=change-me-to-another-long-random-secret

# --- 초기 Owner 계정 ---
BOOTSTRAP_OWNER_EMAIL=owner@example.com
BOOTSTRAP_OWNER_NAME=TeamScope Owner
BOOTSTRAP_OWNER_PASSWORD=ChangeMe123!
