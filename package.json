{
  "name": "team-scope-dashboard",
  "description": "An interactive engineering dashboard that syncs Jira and GitLab data, scores developer and team performance, visualizes Gantt workload, trends, and rankings with filters, and exports Excel reports.",
  "author": "jungtaeinn",
  "version": "0.9.0",
  "license": "Apache-2.0",
  "private": true,
  "engines": {
    "node": ">=22.6.0"
  },
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "dev": "next dev --webpack",
    "db:observability": "node --experimental-strip-types scripts/enable-pg-observability.ts",
    "db:pgstat": "node --experimental-strip-types scripts/report-pg-slow-queries.ts",
    "db:normalize-dates": "node --experimental-strip-types scripts/normalize-db-dates.ts",
    "db:optimize": "node --experimental-strip-types scripts/apply-performance-indexes.ts",
    "db:projects:repair": "node --experimental-strip-types --experimental-specifier-resolution=node scripts/repair-project-identities.ts",
    "db:analytics:init": "node --experimental-strip-types scripts/setup-dashboard-materialized-view.ts",
    "db:analytics:refresh": "node --experimental-strip-types scripts/refresh-dashboard-materialized-view.ts",
    "dev:mac": "bash ./scripts/dev-up.sh",
    "dev:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-up.ps1",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:flow-lab": "node --experimental-strip-types --experimental-specifier-resolution=node --test src/lib/flow-lab/*.test.ts",
    "test:projects": "node --experimental-strip-types --experimental-specifier-resolution=node --test src/lib/projects/*.test.ts"
  },
  "dependencies": {
    "@better-auth/passkey": "1.5.6",
    "@better-auth/prisma-adapter": "1.5.6",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "^7.5.0",
    "@tanstack/react-query": "^5.90.21",
    "better-auth": "1.5.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "nuqs": "^2.8.9",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "node-cron": "^4.2.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "prisma"
    ]
  }
}
